# ─── Python Modules Environment Variables ───
# Copy this file to .env and fill in your values
# This service can be deployed independently
# ── Authentication (MUST match Node.js server's JWT_SECRET) ──
JWT_SECRET=CHANGE_ME_MUST_MATCH_SERVER

# ── Database (MUST match Node.js server's MONGODB_URI) ──
MONGODB_URI=mongodb://127.0.0.1:27017/sociofestdb

# ── Face Encryption (optional — auto-generated if missing in dev) ──
# FACE_ENCRYPTION_KEY=

# ── Google Drive Integration (Optional) ──
# GOOGLE_DRIVE_CREDENTIALS=path/to/credentials.json

# ── Image Generation Settings ──
IMAGE_DEFAULT_STEPS=30
IMAGE_MAX_STEPS=50
IMAGE_OUTPUT_DIR=generated_images
IMAGE_SAVE_DISK=true

# ── GPU Settings (Optional) ──
# CUDA_VISIBLE_DEVICES=0
