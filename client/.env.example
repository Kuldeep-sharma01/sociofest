# ─── Client Environment Variables ───
# Copy this file to .env and fill in your values
# This service can be deployed independently (Vercel, Netlify, Docker)

# ── Backend Gateway URL ──
# In dev mode, Vite proxy forwards /api/* to the Node.js backend on port 5000.
# In production, this should be your deployed backend URL (e.g., https://sociofest-backend.onrender.com)
VITE_BACKEND_URL=http://localhost:5000

# ── Razorpay (optional) ──
VITE_RAZORPAY_KEY_ID=

# ── Firebase (required for auth/storage features) ──
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
